MAX_UPLOAD_MB=30
MAX_IMAGE_FILE_MB=12
MAX_IMAGE_PIXELS=12000000
MAX_IMAGE_DIMENSION=12000
JOB_TTL_SECONDS=86400
JOB_MAX_CONCURRENT=2
PIPELINE_PARALLEL_LOAD=false

AI_MATCH_ENABLED=true
AI_MATCH_API_KEY=replace_with_your_server_key
AI_MATCH_PROVIDER_INDEX=2
AI_MATCH_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MATCH_MODEL=GLM-4-Flash
AI_MATCH_MODE=ai_only
AI_MATCH_TIMEOUT_SECONDS=90
AI_MATCH_CANDIDATE_LIMIT=200
AI_MATCH_SHORTLIST_PER_EVENT=5
AI_MATCH_EVENT_BATCH_SIZE=20
AI_MATCH_EVENT_WORKERS=2
AI_MATCH_MAX_CALLS=30
AI_MATCH_MAX_ELAPSED_SECONDS=600

AI_OCR_ENABLED=true
AI_OCR_PROVIDER_1_NAME=siliconflow
AI_OCR_PROVIDER_1_ENABLED=true
AI_OCR_PROVIDER_1_API_KEY=replace_with_your_siliconflow_key
