AI_MATCH_ENABLED=true
AI_MATCH_API_KEY=replace_with_your_server_key
AI_MATCH_PROVIDER_INDEX=2
AI_MATCH_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MATCH_MODEL=GLM-4-Flash
AI_MATCH_MODE=ai_only
AI_MATCH_TIMEOUT_SECONDS=60
AI_MATCH_CANDIDATE_LIMIT=120
AI_MATCH_EVENT_BATCH_SIZE=30
AI_MATCH_EVENT_WORKERS=3

AI_OCR_ENABLED=true
AI_OCR_PROVIDER_1_NAME=siliconflow
AI_OCR_PROVIDER_1_ENABLED=true
AI_OCR_PROVIDER_1_API_KEY=replace_with_your_siliconflow_key
AI_OCR_PROVIDER_1_BASE_URL=https://api.siliconflow.cn/v1
AI_OCR_PROVIDER_1_MODEL=Qwen/Qwen3-VL-8B-Instruct
AI_OCR_PROVIDER_2_NAME=zhipu
AI_OCR_PROVIDER_2_ENABLED=true
AI_OCR_PROVIDER_2_API_KEY=replace_with_your_zhipu_key
AI_OCR_PROVIDER_2_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_OCR_PROVIDER_2_MODEL=GLM-4V-Flash
AI_OCR_IMAGE_BATCH_SIZE=1
AI_OCR_IMAGE_WORKERS=2
AI_OCR_MAX_TOKENS=8192
AI_OCR_TIMEOUT_SECONDS=90
AI_OCR_LOCAL_FALLBACK=false
AI_OCR_MIN_AGREEMENT_RATIO=0.2
AI_OCR_MIN_EVENTS=1
